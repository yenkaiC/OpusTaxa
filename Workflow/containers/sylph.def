Bootstrap: docker
From: condaforge/miniforge3:latest

%labels
    Author OpusTaxa
    Tool sylph
    Version 0.9.0

%post
    apt-get update && apt-get install -y procps wget && apt-get clean -y
    mamba install -y -c conda-forge -c bioconda \
        sylph=0.9.0 \
        sylph-tax
    mamba clean -a -y

%environment
    export PATH=/opt/conda/bin:$PATH

%runscript
    exec "$@"
